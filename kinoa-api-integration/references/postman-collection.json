            "body": {
              "mode": "raw",
              "raw": "{\n    \"event\" : {\n        \"target_player_id\": \"Illcko2\",\n        \"event_type\": \"gift\",\n        \"event_data\": {\n            \"field1\": \"field_value\",\n            \"field2\": \"field_value\"\n        }\n    }\n\n}",
